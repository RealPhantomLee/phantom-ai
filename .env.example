# phantom-ai Configuration Template
# Copy to .env and fill in your values
# NEVER commit .env to git

# Ollama (LLM inference backend)
OLLAMA_BASE_URL=http://ollama.phantom-ai.svc:11434
OLLAMA_MODEL=llama3.1:8b  # Adjust based on your GPU VRAM

# Kubernetes cluster access
KUBERNETES_SERVICE_HOST=kubernetes.default.svc
KUBERNETES_SERVICE_PORT=443
# Uses in-cluster ServiceAccount token when running as K8s pod

# Voice I/O
AUDIO_INPUT_DEVICE=BlueDragon  # Blue Yeti microphone device name (check `arecord -l`)
AUDIO_OUTPUT_DEVICE=default    # 3.5mm speaker output device
WHISPER_MODEL=distil-large-v3  # faster-whisper model
OPENWAKEWORD_MODEL=alexa       # Wake word model

# TTS (text-to-speech)
PIPER_VOICE=en_US-lessac-medium
PIPER_SPEAKER=0

# Vision
CAMERA_DEVICE=/dev/video0      # Cam Link 4K capture device
YOLO_MODEL=yolov8n             # YOLOv8 model size (n, s, m, l, x)
EDGE_VISION_URL=http://aipi-vision.phantom-ai.svc:8000  # aipi Hailo service

# Gimbal (Bluetooth LE control)
GIMBAL_BLE_ADDRESS=FC:58:FA:XX:XX:XX  # Zhiyun gimbal Bluetooth MAC
GIMBAL_PAN_LIMIT=270     # ±270° from zero (cable-constrained)
GIMBAL_TILT_LIMIT=45
GIMBAL_VELOCITY_LIMIT=90 # max degrees/sec

# Kubernetes Agent settings
K8S_AGENT_APPROVAL_TTL=300     # 5 minutes to approve destructive ops
K8S_AGENT_READ_ONLY_NAMESPACES=kube-system,argocd,tailscale  # never write here
K8S_AGENT_WRITE_NAMESPACES=default,local-ai,vaultkeeper,phantom-ai

# Notifications
TELEGRAM_BOT_TOKEN=                    # Already configured, fetch from K8s Secret
TELEGRAM_CHAT_ID=                      # Already configured, fetch from K8s Secret
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                             # Gmail address
SMTP_PASSWORD=                         # App-specific password
SMTP_FROM=phantom-ai@homelab.local
SMTP_TO=                               # Your email address
REPORT_SCHEDULE=0 18 * * *             # 18:00 daily (cron format)
REPORT_TIMEZONE=America/Chicago        # Adjust for your timezone

# RAG (Retrieval-Augmented Generation)
RAG_VECTOR_DB_URL=http://chroma:8000   # ChromaDB service endpoint
RAG_CHUNK_SIZE=1000
RAG_OVERLAP=100
OBSIDIAN_VAULT_REPO=https://github.com/yourname/obsidian-vault-private  # Private repo with obsidian-git
OBSIDIAN_VAULT_TOKEN=                  # GitHub PAT for private repo

# Redis (state persistence)
REDIS_URL=redis://redis.phantom-ai.svc:6379
REDIS_DB=0

# Logging
LOG_LEVEL=INFO
STRUCTLOG_PROCESSORS=json  # or 'pretty' for development

# Development / Testing
DEBUG=false
VOICE_SIMULATE=false       # Don't actually capture audio
GIMBAL_SIMULATE=false      # Don't actually send BLE commands
K8S_DRY_RUN=false          # Don't actually modify cluster resources
